# Broker: ibkr is the primary target for the exact Ensemble Dual In-Out strategy.
BROKER=ibkr
DRY_RUN=true
DRY_RUN_NET_LIQ=100000
DRY_RUN_CURRENT_CONTRACTS=0

# Artifact bundle
QSENTIA_ARTIFACT_DIR=artifacts/current

# IBKR Gateway / TWS. Use paper account port/client.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=37
IBKR_ACCOUNT=
IBKR_EXCHANGE=CME
IBKR_CONTRACT_SYMBOL=MBT
IBKR_CURRENCY=USD

# Risk. MBT contract size is 0.10 BTC.
TARGET_GROSS_FRACTION=0.90
MAX_CONTRACTS=150
MIN_CONFIDENCE=0.10
REBALANCE_TOLERANCE_CONTRACTS=0
ALLOW_SHORT=true
LIVE_TEXT_MIN_ROWS=5
ALLOW_LOW_LIVE_TEXT=false
ENABLE_YOUTUBE_API=true
YOUTUBE_API_KEY=
YOUTUBE_MAX_SEARCH_CALLS_PER_RUN=2
YOUTUBE_MAX_RESULTS_PER_CALL=25
YOUTUBE_MAX_ROWS=40
YOUTUBE_QUERIES="bitcoin OR BTC cryptocurrency news|bitcoin BTC market analysis"

# Optional Alpaca shadow mode, long/flat only for crypto.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_SYMBOL=BTC/USD
